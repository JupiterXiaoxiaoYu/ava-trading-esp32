{
  "target": "esp32s3",
  "builds": [
    {
      "name": "scratch-arcade",
      "sdkconfig_append": [
        "CONFIG_OTA_URL=\"https://jupdev.tech/xiaozhi/ota/\"",
        "CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y",
        "CONFIG_PARTITION_TABLE_CUSTOM_FILENAME=\"partitions/v2/8m_single.csv\"",
        "# CONFIG_USE_AFE_WAKE_WORD is not set",
        "CONFIG_USE_CUSTOM_WAKE_WORD=y",
        "CONFIG_CUSTOM_WAKE_WORD=\"hey ava\"",
        "CONFIG_CUSTOM_WAKE_WORD_DISPLAY=\"Hey Ava\"",
        "CONFIG_CUSTOM_WAKE_WORD_THRESHOLD=8",
        "# CONFIG_SR_MN_EN_NONE is not set",
        "CONFIG_SR_MN_EN_MULTINET5_SINGLE_RECOGNITION_QUANT8=y",
        "CONFIG_LV_USE_CHART=y",
        "CONFIG_LV_FONT_MONTSERRAT_12=y",
        "CONFIG_LV_FONT_MONTSERRAT_16=y",
        "CONFIG_LV_FONT_MONTSERRAT_24=y",
        "CONFIG_LV_FONT_MONTSERRAT_32=y"
      ]
    }
  ]
}
