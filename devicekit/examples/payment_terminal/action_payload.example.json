{
  "app_id": "solana_payment_terminal_demo",
  "action": "payment.draft",
  "chain": "solana",
  "summary": {
    "title": "Pay merchant",
    "token": "USDC",
    "amount": "0.10",
    "recipient": "merchant.sol"
  },
