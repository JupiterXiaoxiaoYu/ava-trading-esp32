    "level": "medium",
    "reason": "Transfers require explicit physical confirmation."
  },
  "confirm": {
    "required": true,
    "confirm_button": "A",
    "cancel_button": "B",
    "timeout_sec": 30
  },
  "screen": {
    "name": "confirm",
    "payload": {
      "action": "PAY",
      "symbol": "USDC",
      "amount_native": "0.10 USDC",
      "amount_usd": "$0.10"
    }
  }
}
