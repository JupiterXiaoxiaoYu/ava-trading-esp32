{
  "host": "0.0.0.0",
  "http_port": 8788,
  "websocket_port": 8787,
  "public_base_url": "https://ava.example.com",
  "websocket_url": "wss://ava.example.com/ava/v1/",
  "firmware_bin_dir": "data/bin",
  "runtime_state_dir": "data/device_runtime_state",
  "timezone_offset_hours": 8,
  "websocket_ping_interval": 30,
  "websocket_ping_timeout": 10,
  "adapters": {
    "chain": {
      "provider": "solana",
      "options": {
        "data_base": "https://data.ave-api.xyz/v2",
        "api_key_env": "AVE_API_KEY"
      }
    }
  },
  "providers": {
    "asr": {
      "provider": "qwen",
      "base_url": "wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime",
      "model": "qwen3-asr-flash-realtime",
      "api_key_env": "DASHSCOPE_API_KEY",
      "language": "zh",
      "sample_rate": 16000,
      "options": {
        "context": "常用词：Ava、Eva、Ai Wa、艾娃、诶娃、欸娃、AVA、AVE、Hey Ava、Hi Ava、Hello Ava、Ni Hao Ava、代币详情页、详情页、spotlight、feed、钱包、持仓、买入、卖出、pump.fun、Solana、SOL、BONK、WIF。若识别到接近 Ava / Eva / Ai Wa 的发音，优先输出 Ava。",
        "vad_threshold": 0.2,
        "silence_duration_ms": 800
      }
    },
    "llm": {
      "provider": "openai-compatible",
      "base_url": "https://dashscope-intl.aliyuncs.com/compatible-mode/v1",
      "model": "qwen3.5-flash",
      "api_key_env": "DASHSCOPE_API_KEY",
      "options": {
        "temperature": 0.7,
        "max_tokens": 500,
        "top_p": 1,
        "frequency_penalty": 0
      }
    },
    "tts": {
      "provider": "alibl",
      "base_url": "wss://dashscope-intl.aliyuncs.com/api-ws/v1/inference/",
      "model": "cosyvoice-v3-flash",
      "voice": "longanyang",
      "format": "opus",
      "api_key_env": "DASHSCOPE_API_KEY",
      "options": {
        "sample_rate": 16000,
        "volume": 50,
        "rate": 1.0,
        "pitch": 1.0,
        "data_inspection": "enable"
      }
    }
  },
  "audio": {
    "decoder_class": "",
    "options": {}
  },
  "execution": {
    "mode": "custodial",
    "base_url": "https://bot-api.ave.ai",
    "api_key_env": "AVE_API_KEY",
    "secret_key_env": "AVE_SECRET_KEY",
    "proxy_wallet_id_env": "AVE_PROXY_WALLET_ID",
    "proxy_default_gas": "1000000",
    "options": {}
  },
  "services": [
    {
      "id": "proxy_wallet",
      "kind": "custodial_wallet",
      "base_url": "https://bot-api.ave.ai",
      "api_key_env": "AVE_API_KEY",
      "secret_key_env": "AVE_SECRET_KEY",
      "wallet_id_env": "AVE_PROXY_WALLET_ID",
      "capabilities": [
        "wallet.balance",
        "trade.market",
        "trade.limit",
        "order.status"
      ],
      "options": {
        "confirmation_required": "device_screen",
        "allowed_paths": [
          "/orders",
          "/orders/status",
          "/wallet/balance"
        ],
        "invocable": false
      }
    },
    {
      "id": "market_data",
      "kind": "market_data_api",
      "base_url": "https://data.ave-api.xyz/v2",
      "api_key_env": "AVE_API_KEY",
      "capabilities": [
        "token.feed",
        "token.search",
        "token.detail",
        "price.stream"
      ],
      "options": {
        "invocable": false
      }
    }
  ],
  "production_mode": false
}
