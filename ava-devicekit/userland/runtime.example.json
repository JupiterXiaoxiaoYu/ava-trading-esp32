{
  "host": "0.0.0.0",
  "http_port": 8788,
  "websocket_port": 8787,
  "public_base_url": "https://ava.example.com",
  "websocket_url": "wss://ava.example.com/ava/v1/",
  "firmware_bin_dir": "data/bin",
  "timezone_offset_hours": 8,
  "websocket_ping_interval": 30,
  "websocket_ping_timeout": 10,
  "providers": {
    "asr": {
      "provider": "qwen",
      "base_url": "wss://dashscope.aliyuncs.com/api-ws/v1/realtime",
      "model": "qwen3-asr-flash-realtime",
      "api_key_env": "DASHSCOPE_API_KEY",
      "language": "zh",
      "sample_rate": 16000
    },
    "llm": {
      "provider": "openai-compatible",
      "base_url": "https://api.openai.com/v1",
      "model": "gpt-4o-mini",
      "api_key_env": "OPENAI_API_KEY"
    },
    "tts": {
      "provider": "openai-compatible",
      "base_url": "https://api.openai.com/v1",
      "model": "gpt-4o-mini-tts",
      "voice": "alloy",
      "format": "opus",
      "api_key_env": "OPENAI_API_KEY"
    }
  },
  "audio": {
    "decoder_class": "",
    "options": {}
  },
  "execution": {
    "mode": "custodial",
    "base_url": "https://bot-api.ave.ai",
    "api_key_env": "AVE_API_KEY",
    "secret_key_env": "AVE_SECRET_KEY",
    "proxy_wallet_id_env": "AVE_PROXY_WALLET_ID",
    "proxy_default_gas": "1000000"
  }
}
