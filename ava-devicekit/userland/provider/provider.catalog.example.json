{
  "providers": {
    "asr": {
      "qwen_realtime": {
        "provider": "qwen",
        "base_url": "wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime",
        "model": "qwen3-asr-flash-realtime",
        "api_key_env": "DASHSCOPE_API_KEY",
        "language": "zh",
        "sample_rate": 16000,
        "options": {
          "context": "常用词：Ava、Eva、Ai Wa、艾娃、诶娃、欸娃、AVA、AVE、Hey Ava、Hi Ava、Hello Ava、Ni Hao Ava、代币详情页、详情页、spotlight、feed、钱包、持仓、买入、卖出、pump.fun、Solana、SOL、BONK、WIF。若识别到接近 Ava / Eva / Ai Wa 的发音，优先输出 Ava。",
          "vad_threshold": 0.2,
          "silence_duration_ms": 800
        }
      },
      "openai_compatible_transcription": {
        "provider": "openai-compatible",
        "base_url": "https://api.openai.com/v1",
        "model": "whisper-1",
        "api_key_env": "OPENAI_API_KEY",
        "language": "en"
      },
      "custom_python_provider": {
        "provider": "custom",
        "class": "my_app.providers.MyASRProvider",
        "options": {
          "base_url": "https://asr.example.com",
          "api_key_env": "MY_ASR_KEY",
          "model": "my-asr-model"
        }
      }
    },
    "llm": {
      "openai": {
        "provider": "openai-compatible",
        "base_url": "https://api.openai.com/v1",
        "model": "gpt-4o-mini",
        "api_key_env": "OPENAI_API_KEY"
      },
      "deepseek_or_compatible": {
        "provider": "openai-compatible",
        "base_url": "https://api.deepseek.com/v1",
        "model": "deepseek-chat",
        "api_key_env": "DEEPSEEK_API_KEY"
      },
      "custom_python_provider": {
        "provider": "custom",
        "class": "my_app.providers.MyLLMProvider",
        "options": {
          "base_url": "https://llm.example.com",
          "api_key_env": "MY_LLM_KEY",
          "model": "my-llm-model"
        }
      }
    },
    "tts": {
      "mock": {
        "provider": "mock"
      },
      "openai_compatible_speech": {
        "provider": "openai-compatible",
        "base_url": "https://api.openai.com/v1",
        "model": "gpt-4o-mini-tts",
        "voice": "alloy",
        "format": "opus",
        "api_key_env": "OPENAI_API_KEY"
      },
      "custom_python_provider": {
        "provider": "custom",
        "class": "my_app.providers.MyTTSProvider",
        "options": {
          "base_url": "https://tts.example.com",
          "api_key_env": "MY_TTS_KEY",
          "model": "my-tts-model",
          "voice": "ava"
        }
      },
      "alibl_cosyvoice": {
        "provider": "alibl",
        "base_url": "wss://dashscope-intl.aliyuncs.com/api-ws/v1/inference/",
        "model": "cosyvoice-v3-flash",
        "voice": "longanyang",
        "format": "opus",
        "api_key_env": "DASHSCOPE_API_KEY",
        "options": {
          "sample_rate": 16000,
          "volume": 50,
          "rate": 1.0,
          "pitch": 1.0,
          "data_inspection": "enable"
        }
      }
    }
  },
  "execution": {
    "paper": {
      "mode": "paper"
    },
    "ava_proxy_wallet": {
      "mode": "custodial",
      "base_url": "https://bot-api.ave.ai",
      "api_key_env": "AVE_API_KEY",
      "secret_key_env": "AVE_SECRET_KEY",
      "proxy_wallet_id_env": "AVE_PROXY_WALLET_ID"
    },
    "custom_python_executor": {
      "mode": "custom",
      "class": "my_app.execution.MyTradeExecutor",
      "options": {
        "base_url": "https://trade.example.com",
        "api_key_env": "MY_TRADE_API_KEY"
      }
    }
  }
}
