{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ava-devicekit.dev/schemas/device_identity.schema.json",
  "title": "Ava DeviceKit Device Identity",
  "type": "object",
  "required": ["device_id"],
  "properties": {
    "device_id": {"type": "string", "minLength": 1},
    "device_public_key": {"type": "string"},
    "key_type": {"type": "string", "enum": ["ed25519", "secp256k1", "unknown", "none"]},
    "secure_element_profile": {"type": "string"},
    "challenge": {"type": "object", "additionalProperties": true},
    "signature": {"type": "string"},
    "attestation": {"type": "object", "additionalProperties": true},
    "metadata": {"type": "object", "additionalProperties": true}
  },
  "additionalProperties": true
}
